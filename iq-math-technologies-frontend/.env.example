# Frontend Environment Variables
# Copy to .env.local for local development
# For Cloudflare Pages: set VITE_AGENT_API_URL as an environment variable in the Pages project settings

# Local dev — point at your local backend
VITE_AGENT_API_URL=http://127.0.0.1:8000

# Production — replace with your Render backend URL after deploying
# VITE_AGENT_API_URL=https://nexperts-academy-backend.onrender.com
