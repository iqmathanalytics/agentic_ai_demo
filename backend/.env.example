# Backend Environment Variables
# Copy to .env for local development
# For Render: set these in the Render service → Environment tab

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://nexperts-academy.pages.dev,https://www.nexpertsai.com

# --- Market data providers (optional — agent degrades gracefully without them) ---
ALPHA_VANTAGE_KEY=
FINNHUB_KEY=
FMP_KEY=

# --- Search providers (optional — improves stock research quality) ---
TAVILY_API_KEY=
SERPER_API_KEY=

# --- AI providers (users enter keys in the UI; these are server-side fallbacks) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=gsk_...
